# Copie ce fichier en .env.local pour le développement,
# et configure ces deux variables dans Vercel (Project Settings → Environment Variables).
# Sans elles, l'application fonctionne quand même mais enregistre seulement
# sur l'appareil (localStorage), sans synchronisation entre utilisateurs.

VITE_SUPABASE_URL=https://VOTRE-PROJET.supabase.co
VITE_SUPABASE_ANON_KEY=votre_cle_anon_publique
